{
  "_comment": "JSON Schema with realistic examples for performance-synthesizer. Entities: Epic, Ticket, Engineer, Commit.",

  "schemas": {
    "epic": {
      "_description": "A large body of work tracked across multiple Jira tickets",
      "fields": {
        "id":              "string  — internal UUID",
        "epic_key":        "string  — Jira-style key e.g. PLAT-EPIC-1",
        "title":           "string",
        "goal_statement":  "string  — one-sentence business objective",
        "start_date":      "ISO-8601 date",
        "end_date":        "ISO-8601 date",
        "criticality":     "enum: critical | high | medium | low",
        "status":          "enum: in_progress | completed | cancelled"
      }
    },
    "ticket": {
      "_description": "A single Jira issue belonging to an epic",
      "fields": {
        "ticket_id":        "string  — Jira-style key e.g. PLAT-42",
        "epic_id":          "string  — references epic.id",
        "title":            "string",
        "description":      "string",
        "estimate_hours":   "number  — original story-point estimate converted to hours",
        "actual_hours":     "number  — hours logged on completion",
        "status":           "enum: todo | in_progress | in_review | blocked | done",
        "complexity":       "enum: low | medium | high | very_high",
        "engineer_assigned":"string  — references engineer.engineer_id",
        "sprint":           "string",
        "created_date":     "ISO-8601 date",
        "resolved_date":    "ISO-8601 date | null",
        "blockers":         "array of {reason: string, resolved: bool}"
      }
    },
    "engineer": {
      "_description": "A software engineer whose output is being assessed",
      "fields": {
        "engineer_id":    "string",
        "name":           "string",
        "role":           "enum: junior | mid | senior | staff",
        "specialization": "string  — primary technical domain",
        "tenure_months":  "number  — months at the company",
        "team":           "string"
      }
    },
    "commit": {
      "_description": "A git commit linked to a Jira ticket",
      "fields": {
        "commit_hash":  "string  — 7-char short SHA",
        "message":      "string  — conventional commit or free-form",
        "timestamp":    "ISO-8601 datetime",
        "engineer_id":  "string  — references engineer.engineer_id",
        "ticket_id":    "string  — references ticket.ticket_id",
        "files_changed":"number",
        "insertions":   "number",
        "deletions":    "number"
      }
    }
  },

